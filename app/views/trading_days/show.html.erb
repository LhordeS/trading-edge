<h1>
  <%= @trading_day.symbol %>
  <%= @trading_day.date %>
</h1>
<p>Candles: <%= @trading_day.candles.count %></p>

<h2>Candlestick Chart</h2>

<div
  id="candlestick-chart"
  style="width: 100%; height: 500px; border: 1px solid #ddd"
  ></div>

<script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
<script id="candles-data" type="application/json">
  <%= raw @candles.to_json(
    only: [:timestamp, :open, :high, :low, :close]
  ) %>
</script>

<div class="opening-range-analysis-card">
  <p><strong>Breakout: </strong><%= @opening_range_analysis.breakout? %></p>
  <p><strong>Breakout Direction: </strong><%= @opening_range_analysis.breakout_direction %></p>
  <p><strong>Time to Breakout: </strong><%= @opening_range_analysis.minutes_to_breakout %> minutes</p>
  <p><strong>MFE: </strong><%= @opening_range_analysis.maximum_favorable_excursion %> handles</p>
  <p><strong>MAE: </strong><%= @opening_range_analysis.maximum_adverse_excursion %> handles</p>
</div>

<table>
  <thead>
    <tr>
      <th>Time</th>
      <th>Open</th>
      <th>High</th>
      <th>Low</th>
      <th>Close</th>
      <th>Volume</th>
    </tr>
  </thead>

  <tbody>
    <% @candles.each do |candle| %>
      <tr>
        <td><%= candle.timestamp %></td>
        <td><%= candle.open %></td>
        <td><%= candle.high %></td>
        <td><%= candle.low %></td>
        <td><%= candle.close %></td>
        <td><%= candle.volume %></td>
      </tr>
    <% end %>
  </tbody>
</table>
